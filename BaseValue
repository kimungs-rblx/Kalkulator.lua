-- Fungsi Pembantu Membuat Input Form Mini
local function createInputField(labelName, defaultVal, posY)
    local label = Instance.new("TextLabel")
    label.Parent = MainFrame
    label.BackgroundTransparency = 1
    label.Position = UDim2.new(0, 12, 0, posY)
    label.Size = UDim2.new(1, -24, 0, 10)
    label.Font = Enum.Font.SourceSansBold
    label.Text = labelName
    label.TextColor3 = Color3.fromRGB(44, 62, 80)
    label.TextSize = 9
    label.TextXAlignment = Enum.TextXAlignment.Left

    local input = Instance.new("TextBox")
    input.Parent = MainFrame
    input.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    input.Position = UDim2.new(0, 12, 0, posY + 12)
    input.Size = UDim2.new(1, -24, 0, 18)
    input.Font = Enum.Font.SourceSans
    input.Text = defaultVal
    input.TextColor3 = Color3.fromRGB(44, 62, 80)
    input.TextSize = 10
    
    local inputCorner = Instance.new("UICorner")
    inputCorner.CornerRadius = UDim.new(0, 4)
    inputCorner.Parent = input

    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(220, 221, 225)
    stroke.Thickness = 1
    stroke.Parent = input

    input.Focused:Connect(function() stroke.Color = Color3.fromRGB(231, 76, 60) end)
    input.FocusLost:Connect(function() stroke.Color = Color3.fromRGB(220, 221, 225) end)

    return input
end

